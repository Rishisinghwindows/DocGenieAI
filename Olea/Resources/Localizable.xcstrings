    "Save where each document was scanned or imported. Off by default." : {
      "comment" : "Settings: Location toggle description",
      "localizations" : {
        "ar" : { "stringUnit" : { "state" : "translated", "value" : "احفظ مكان مسح كل مستند أو استيراده. متوقف افتراضيًا." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Guarda dónde se escaneó o importó cada documento. Desactivado por defecto." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Enregistre où chaque document a été scanné ou importé. Désactivé par défaut." } },
        "hi" : { "stringUnit" : { "state" : "translated", "value" : "हर दस्तावेज़ कहाँ स्कैन या आयात किया गया, सहेजें। डिफ़ॉल्ट रूप से बंद।" } }
      }
    },
    "Surface your documents in Spotlight, Lock Screen search, and Siri Suggestions. Vault files are never indexed." : {
      "comment" : "Settings: Spotlight toggle description",
      "localizations" : {
        "ar" : { "stringUnit" : { "state" : "translated", "value" : "إظهار مستنداتك في Spotlight وبحث شاشة القفل واقتراحات Siri. لا تُفهرس ملفات الخزنة أبدًا." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Muestra tus documentos en Spotlight, búsqueda de la pantalla bloqueada y sugerencias de Siri. Los archivos de la bóveda nunca se indexan." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Affichez vos documents dans Spotlight, la recherche d'écran verrouillé et les suggestions Siri. Les fichiers du coffre ne sont jamais indexés." } },
        "hi" : { "stringUnit" : { "state" : "translated", "value" : "अपने दस्तावेज़ों को Spotlight, लॉक स्क्रीन खोज और Siri सुझावों में दिखाएं। वॉल्ट फ़ाइलें कभी अनुक्रमित नहीं होतीं।" } }
